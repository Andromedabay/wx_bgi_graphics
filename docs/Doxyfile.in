PROJECT_NAME           = "wx_BGI_Graphics"
PROJECT_BRIEF          = "Classic BGI-compatible graphics API with modern OpenGL extension API"
OUTPUT_DIRECTORY       = "@DOXYGEN_OUTPUT_DIR@"
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO

OPTIMIZE_OUTPUT_FOR_C  = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = NO

INPUT                  = "@CMAKE_SOURCE_DIR@/README.md" \
                         "@CMAKE_SOURCE_DIR@/src/wx_bgi.h" \
                         "@CMAKE_SOURCE_DIR@/src/wx_bgi_ext.h" \
                         "@CMAKE_SOURCE_DIR@/src/bgi_types.h" \
                         "@CMAKE_SOURCE_DIR@/Tutorial.md" \
                         "@CMAKE_SOURCE_DIR@/bgidemo-pascal/README.md" \
                         "@CMAKE_SOURCE_DIR@/images/DoubleBuffering.png" \
                         "@CMAKE_SOURCE_DIR@/images/Minimum_Buffers_for_Double_buffering.png"
FILE_PATTERNS          = *.h *.md *.png
RECURSIVE              = NO
USE_MDFILE_AS_MAINPAGE = "@CMAKE_SOURCE_DIR@/README.md"

GENERATE_HTML          = YES
GENERATE_LATEX         = YES
USE_PDFLATEX           = YES
GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_DOCBOOK       = NO

JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
PREDEFINED             = WXBGI_ENABLE_TEST_SEAMS
LATEX_EXTRA_STYLESHEET = "@CMAKE_SOURCE_DIR@/docs/doxygen-unicode.tex"

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES

STRIP_FROM_PATH        = "@CMAKE_SOURCE_DIR@"
FULL_PATH_NAMES        = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
